# Copy to .env.docker and fill in secrets. Container reaches host DB/Redis via host.docker.internal.

SECRET_KEY=replace-with-a-long-random-string
DB_PASSWORD=your-postgres-password

POSTGRES_HOST=host.docker.internal
# If migrate fails with IPv6 "Network is unreachable", try the Docker bridge gateway (often 172.17.0.1 on Linux) or your LAN IP.
# POSTGRES_HOST=172.17.0.1
POSTGRES_PORT=5432
POSTGRES_DB=sponsorblock
POSTGRES_USER=sponsorblock

# e.g. redis://host.docker.internal:6379/1  or  redis://:password@host.docker.internal:6379/1
REDIS_URL=redis://host.docker.internal:6379/1

# Must match the path used at docker build (static files are baked into the image)
STATIC_ROOT=/app/staticfiles

# Optional tuning
# GUNICORN_BIND_PORT=8000
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=1
# GUNICORN_TIMEOUT=120

# If you access the container directly over plain HTTP (no reverse proxy), set these to false:
# SECURE_SSL_REDIRECT=false
# SESSION_COOKIE_SECURE=false
# CSRF_COOKIE_SECURE=false
